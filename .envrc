source scripts/activate_autoware.sh

# Overlay locally-built rmw_zenoh_cpp if available
if [ -f external/rmw_zenoh_ws/install/local_setup.bash ]; then
  source external/rmw_zenoh_ws/install/local_setup.bash
fi

# Use rmw_zenoh_cpp as the ROS 2 middleware
export RMW_IMPLEMENTATION=rmw_zenoh_cpp

# Point rmw_zenoh_cpp at our config files (client mode → tcp/localhost:7447)
export ZENOH_SESSION_CONFIG_URI="$(pwd)/.config/zenoh_session.json5"
export ZENOH_ROUTER_CONFIG_URI="$(pwd)/.config/zenoh_router.json5"
