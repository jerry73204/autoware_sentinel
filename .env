# Sentinel build-time configuration (zpico + nros compile-time limits)
ZPICO_MAX_PUBLISHERS=56
ZPICO_MAX_SUBSCRIBERS=16
ZPICO_MAX_QUERYABLES=32
ZPICO_MAX_LIVELINESS=96
NROS_MAX_PARAMETERS=64
NROS_EXECUTOR_MAX_CBS=96
NROS_PARAM_SERVICE_BUFFER_SIZE=8192

# Sentinel runtime configuration
ZENOH_LOCATOR=tcp/127.0.0.1:7447
RUST_LOG=info
